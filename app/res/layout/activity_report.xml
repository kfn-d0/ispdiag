<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="36dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_report"
                android:textSize="24sp"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tv_report_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Relatorio tecnico com inferencia"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_toggle_view"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="JSON"
            android:textColor="@color/primary_light"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_card_elevated"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

    <!-- Report Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/tv_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_code_block"
            android:padding="16dp"
            android:layout_marginBottom="80dp" />
    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_bar"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="20dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/btn_copy"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_copy"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_export"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_export_json"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_accent"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btn_share"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/btn_share"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginStart="4dp" />
    </LinearLayout>
</LinearLayout>
