<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="36dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Historico"
                android:textSize="24sp"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tv_history_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 diagnosticos salvos"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_github_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="github.com/kfn-d0"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:clickable="true" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_clear_history"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Limpar"
            android:textColor="@color/status_fail"
            android:textSize="12sp"
            android:background="@drawable/bg_card_elevated"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty_history"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Nenhum diagnostico salvo ainda.\nExecute um diagnostico para ver o historico."
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"
        android:padding="32dp" />

    <!-- History List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/history_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="100dp" />
    </ScrollView>

    <!-- Back -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_bar"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Voltar"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_secondary" />
    </LinearLayout>
</LinearLayout>
