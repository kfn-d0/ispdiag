<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- Service Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Status Dot -->
        <View
            android:id="@+id/status_indicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_ok" />

        <TextView
            android:id="@+id/tv_result_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tv_result_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:background="@drawable/badge_ok" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <!-- Test Results Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- DNS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_elevated"
            android:padding="8dp"
            android:layout_marginEnd="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_dns"
                android:textColor="@color/text_hint"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tv_dns_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- TCP -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_elevated"
            android:padding="8dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_tcp"
                android:textColor="@color/text_hint"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tv_tcp_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- TLS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_elevated"
            android:padding="8dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_tls"
                android:textColor="@color/text_hint"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tv_tls_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- HTTP -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_card_elevated"
            android:padding="8dp"
            android:layout_marginStart="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_http"
                android:textColor="@color/text_hint"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tv_http_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Total Time -->
    <TextView
        android:id="@+id/tv_total_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        android:layout_marginTop="10dp"
        android:gravity="end" />

    <!-- Details Button -->
    <Button
        android:id="@+id/btn_details"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="@string/btn_details"
        android:textColor="@color/primary_light"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/bg_card_elevated"
        android:layout_marginTop="10dp" />
</LinearLayout>
