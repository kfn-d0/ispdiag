<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tv_history_timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/primary_light"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Services tested -->
    <TextView
        android:id="@+id/tv_history_services"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <!-- Status row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_history_ok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_ok"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/badge_ok"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_history_partial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_partial"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/badge_partial"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_history_fail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_fail"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/badge_fail" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_history_view"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Ver JSON"
            android:textColor="@color/primary_light"
            android:textSize="11sp"
            android:background="@drawable/bg_card_elevated"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />
    </LinearLayout>
</LinearLayout>
